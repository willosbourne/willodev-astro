---
import { ViewTransitions } from 'astro:transitions';
import { fade } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
interface Props {
	pageTitle: string;
	description?: string;
	ogImage?: string | null;
}

const { pageTitle, description, ogImage } = Astro.props;
const metaDescription = description || "Will Osbourne — software engineer, writer, and maker.";
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://willo.dev';

const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiEnabled = import.meta.env.PROD && umamiSrc && umamiWebsiteId;
---
<!DOCTYPE html>
<html transition:animate="none" lang="en">
	<head>
        <meta charset="utf-8" />
        <meta name="description" content={metaDescription}>
        <meta property="og:title" content={pageTitle}>
        <meta property="og:description" content={metaDescription}>
        <meta property="og:type" content="website">
        {ogImage && <meta property="og:image" content={ogImage}>}
        <link rel="alternate" type="application/rss+xml" title="willo.dev" href={`${siteUrl}/rss.xml`}>
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="preload" href="https://fonts.googleapis.com/css2?family=Josefin+Sans&family=Pacifico&display=swap" as="style">
        <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans&family=Pacifico&display=swap" rel="stylesheet">
        {umamiEnabled && (
            <script
                is:inline
                defer
                src={umamiSrc}
                data-website-id={umamiWebsiteId}
                data-auto-track="false"
                data-domains="willo.dev"
            ></script>
        )}
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
        <ViewTransitions />
	</head>
	<body>
        <Header />
        <main transition:animate={fade({ duration: '0.2s' })} >
	    <slot />
            <Footer />
        </main>
        <script>
            function colorMode() {
                if (
                    localStorage.theme === "light" ||
                    (!("theme" in localStorage) &&
                    window.matchMedia("(prefers-color-scheme: light)").matches)
                ) {
                    document.documentElement.classList.add("light");
                } else {
                    document.documentElement.classList.remove("light");
                }
              }

            colorMode();
            document.addEventListener('astro:after-swap', colorMode);

            let lastTrackedPath = '';
            function trackPageview() {
                if (typeof window.umami === 'undefined') return;
                const path = location.pathname + location.search;
                if (path === lastTrackedPath) return;
                lastTrackedPath = path;
                try { window.umami.track(); } catch { /* never break the page */ }
            }

            function handleAnchorClick(event: MouseEvent) {
                if (typeof window.umami === 'undefined') return;
                const target = event.target;
                if (!(target instanceof Element)) return;
                const anchor = target.closest('a');
                if (!anchor) return;
                const href = anchor.getAttribute('href');
                if (!href) return;

                if (href === '/rss.xml') {
                    try { window.umami.track('rss-click'); } catch {}
                    return;
                }

                if (!/^https?:\/\//i.test(href)) return;
                try {
                    const url = new URL(href);
                    if (url.host === location.host) return;
                    window.umami.track('outbound-link', { url: url.toString() });
                } catch { /* malformed URL — skip */ }
            }

            document.addEventListener('astro:page-load', trackPageview);
            document.addEventListener('click', handleAnchorClick, { capture: true });
        </script>
	</body>
</html>

