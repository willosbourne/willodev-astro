# Ghost CMS (headless content source)
GHOST_URL=
GHOST_CONTENT_API_KEY=

# Umami analytics (production only)
# Set these in the deploy provider's "production" context ONLY.
# Leaving them unset in dev / deploy previews is intentional — the tracker
# script is gated on `import.meta.env.PROD && PUBLIC_UMAMI_SRC && PUBLIC_UMAMI_WEBSITE_ID`.
# Example values:
#   PUBLIC_UMAMI_SRC=https://umami.willo.dev/stats.js
#   PUBLIC_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=
